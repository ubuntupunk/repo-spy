REPOS=(
  "$HOME/Projects/netbones"
  "$HOME/Projects/flearadar"
  "$HOME/Projects/soralia-village"
  "$HOME/Projects/startup-connect"
)
OUTPUT="$HOME/.repo-spy/data.json"

collect_repo() {
  local dir=$1
  local name=$(basename "$dir")

  cd "$dir" || return

  # Git: today's commits
  local commits=$(git log --since="midnight" --format='{"hash":"%h","msg":"%s","time":"%cr","author":"%an"}' | jq -s .)

  # Current branch
  local branch=$(git branch --show-current)

  # Beads issues
  local issues=$(bd list --json)

  # GSD planning
  local planning_phases="[]"
  local planning_todos=""
  local planning_state=""
  local last_completed_phase=""
  local next_phase=""
  local planning_last_completed_plan=""
  local planning_next_plan=""
  if [ -d ".planning" ]; then
    # Phases
    if [ -d ".planning/phases" ]; then
      planning_phases=$(find ".planning/phases" -mindepth 1 -maxdepth 1 -type d -printf '%P\n' | sort -n | while read -r phase_dir; do
        local num=$(echo "$phase_dir" | sed 's/-.*//')
        local name_phase=$(echo "$phase_dir" | sed 's/^[0-9][0-9]-//')
        local completed="false"
        if [ -f ".planning/phases/$phase_dir/${num}-01-SUMMARY.md" ]; then
          completed="true"
        fi
        local description=""
        if [ -f ".planning/phases/$phase_dir/${num}-01-PLAN.md" ]; then
          description=$(head -1 ".planning/phases/$phase_dir/${num}-01-PLAN.md" | sed 's/^# //' | sed 's/^#//')
        fi
        echo "{\"number\":\"$num\",\"name\":\"$name_phase\",\"completed\":$completed,\"description\":\"$description\"}"
      done | jq -s .)
    fi

    # Derive last completed and next phase
    last_completed_phase=$(echo "$planning_phases" | jq -r 'map(select(.completed == true)) | last | .name // ""')
    next_phase=$(echo "$planning_phases" | jq -r 'map(select(.completed == false)) | first | .name // ""')

    # Todos
    if [ -d ".planning/todos/pending" ]; then
      planning_todos=$(find ".planning/todos/pending" -name "*.md" | wc -l)
    fi

    # State
    if [ -f ".planning/STATE.md" ]; then
      planning_state=$(head -n 5 ".planning/STATE.md" | tr '\n' ' ' | sed 's/  */ /g')
    fi

    # Roadmap sections
    if [ -f ".planning/ROADMAP.md" ]; then
      planning_last_completed_plan=$(sed -n '/^## Last Completed Plan/,/^## /{p}' ".planning/ROADMAP.md" | sed '1d;$d' | head -20 | tr '\n' ' ' | sed 's/  */ /g')
      planning_next_plan=$(sed -n '/^## Next Plan/,/^## /{p}' ".planning/ROADMAP.md" | sed '1d;$d' | head -20 | tr '\n' ' ' | sed 's/  */ /g')
    fi
  fi
  jq -n \
    --arg name "$name" \
    --arg dir "$dir" \
    --arg branch "$branch" \
    --argjson commits "$commits" \
    --argjson issues "$issues" \
    --argjson planning_phases "$planning_phases" \
    --arg planning_todos "$planning_todos" \
    --arg planning_state "$planning_state" \
    --arg last_completed_phase "$last_completed_phase" \
    --arg next_phase "$next_phase" \
    --arg planning_last_completed_plan "$planning_last_completed_plan" \
    --arg planning_next_plan "$planning_next_plan" \
    '{name:$name, dir:$dir, branch:$branch, commits:$commits, issues:$issues, planning_phases:$planning_phases, planning_todos:$planning_todos, planning_state:$planning_state, last_completed_phase:$last_completed_phase, next_phase:$next_phase, planning_last_completed_plan:$planning_last_completed_plan, planning_next_plan:$planning_next_plan}'
}

# Ensure output directory exists
if [ ! -d "$HOME/.repo-spy" ]; then
  mkdir -p "$HOME/.repo-spy"
fi

# Collect all repos, merge into one JSON array
data=$(for r in "${REPOS[@]}"; do collect_repo "$r"; done | jq -s .)
echo "{\"repos\":$data,\"synced\":\"$(date -Iseconds)\"}" >"$OUTPUT"
